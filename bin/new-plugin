#!/usr/bin/env bash
# new-plugin — scaffold a new plugin from a template
#
# Usage:
#   bin/new-plugin <type> <name>
#
#   type   skill | agent | hook | mcp
#   name   kebab-case name for the new plugin (e.g. my-formatter)
#
# skill/agent: creates plugins/<name>/ from template, replaces placeholders.
# hook:        creates config/hooks/<name>.sh from template.
# mcp:         adds servers/<name>/ and .mcp.json to an existing plugins/<name>/.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TEMPLATES_DIR="$REPO_ROOT/templates"
PLUGINS_DIR="$REPO_ROOT/plugins"
CONFIG_HOOKS_DIR="$REPO_ROOT/config/hooks"

usage() {
  echo "Usage: $(basename "$0") <type> <name>"
  echo ""
  echo "  type   skill | agent | hook | mcp"
  echo "  name   kebab-case name (e.g. my-formatter, code-reviewer)"
  echo ""
  echo "Examples:"
  echo "  $(basename "$0") skill  my-formatter"
  echo "  $(basename "$0") agent  code-reviewer"
  echo "  $(basename "$0") hook   my-guard"
  echo "  $(basename "$0") mcp    my-formatter  # adds MCP server to existing plugin"
  exit 1
}

[[ $# -ne 2 ]] && usage

TYPE="$1"
NAME="$2"

# Validate type
case "$TYPE" in
  skill|agent|hook|mcp) ;;
  *) echo "Error: type must be skill, agent, hook, or mcp" >&2; usage ;;
esac

# Validate name: lowercase, digits, hyphens; must start with a letter
if [[ ! "$NAME" =~ ^[a-z][a-z0-9-]*$ ]]; then
  echo "Error: name must be lowercase kebab-case starting with a letter (e.g. my-tool)" >&2
  exit 1
fi

# ── Hook type: scaffold into config/hooks/ ────────────────────────────────────

if [[ "$TYPE" == "hook" ]]; then
  HOOK_TEMPLATE="$TEMPLATES_DIR/hooks/hook.sh"
  DEST="$CONFIG_HOOKS_DIR/$NAME.sh"

  if [[ ! -f "$HOOK_TEMPLATE" ]]; then
    echo "Error: hook template not found at $HOOK_TEMPLATE" >&2
    exit 1
  fi

  if [[ -f "$DEST" ]]; then
    echo "Error: $DEST already exists" >&2
    exit 1
  fi

  mkdir -p "$CONFIG_HOOKS_DIR"
  sed "s/HOOK_NAME/$NAME/g" "$HOOK_TEMPLATE" > "$DEST"
  chmod +x "$DEST"

  echo "Created: $DEST"
  echo ""
  echo "Next steps:"
  echo "  1. Edit $DEST"
  echo "     → add your guard/check logic"
  echo "  2. Wire into config/settings.json under hooks.PreToolUse or hooks.PostToolUse:"
  echo "     { \"matcher\": \"Bash|Edit|Write\", \"hooks\": [{ \"type\": \"command\", \"command\": \"~/.claude/hooks/$NAME.sh\" }] }"
  echo "  3. Apply to ~/.claude/:"
  echo "     bin/sync-config push"
  exit 0
fi

# ── MCP type: add server scaffolding to an existing plugin ────────────────────

if [[ "$TYPE" == "mcp" ]]; then
  MCP_TEMPLATE="$TEMPLATES_DIR/mcp"
  DEST="$PLUGINS_DIR/$NAME"
  PLUGIN_JSON="$DEST/.claude-plugin/plugin.json"

  if [[ ! -d "$MCP_TEMPLATE" ]]; then
    echo "Error: mcp template not found at $MCP_TEMPLATE" >&2
    exit 1
  fi

  if [[ ! -d "$DEST" ]]; then
    echo "Error: plugins/$NAME does not exist — create the plugin first:" >&2
    echo "  bin/new-plugin skill $NAME" >&2
    exit 1
  fi

  if [[ -f "$DEST/.mcp.json" ]]; then
    echo "Error: plugins/$NAME/.mcp.json already exists" >&2
    exit 1
  fi

  if [[ ! -f "$PLUGIN_JSON" ]]; then
    echo "Error: $PLUGIN_JSON not found — is plugins/$NAME a valid plugin?" >&2
    exit 1
  fi

  # Copy server files and .mcp.json from template
  cp -r "$MCP_TEMPLATE/servers/PLUGIN_NAME" "$DEST/servers/$NAME"
  cp "$MCP_TEMPLATE/.mcp.json" "$DEST/.mcp.json"

  # Token substitution in the new files only
  find "$DEST/servers/$NAME" "$DEST/.mcp.json" -type f | while IFS= read -r file; do
    sed -i -e "s/PLUGIN_NAME/$NAME/g" "$file"
  done

  # Make launchers executable
  chmod +x "$DEST/servers/$NAME/run.sh"
  chmod +x "$DEST/servers/$NAME/docker/run.sh"

  # Patch plugin.json to add mcpConfig key
  python3 - "$PLUGIN_JSON" <<'EOF'
import json, sys
with open(sys.argv[1]) as f:
    d = json.load(f)
d["mcpConfig"] = "./.mcp.json"
with open(sys.argv[1], "w") as f:
    json.dump(d, f, indent=2)
    f.write("\n")
EOF

  echo "Updated: plugins/$NAME"
  echo "  + servers/$NAME/"
  echo "  + .mcp.json"
  echo "  + mcpConfig key added to .claude-plugin/plugin.json"
  echo ""
  echo "Next: edit servers/$NAME/run_server.py to implement your tools, then:"
  echo "  claude --plugin-dir $DEST"
  exit 0
fi

# ── Plugin types: scaffold into plugins/ ──────────────────────────────────────

TEMPLATE_SRC="$TEMPLATES_DIR/$TYPE"
DEST="$PLUGINS_DIR/$NAME"

if [[ ! -d "$TEMPLATE_SRC" ]]; then
  echo "Error: template not found at $TEMPLATE_SRC" >&2
  exit 1
fi

if [[ -d "$DEST" ]]; then
  echo "Error: $DEST already exists" >&2
  exit 1
fi

# --- Copy ---
cp -r "$TEMPLATE_SRC" "$DEST"

# --- Rename placeholder directories ---
[[ -d "$DEST/skills/SKILL_NAME" ]] && mv "$DEST/skills/SKILL_NAME" "$DEST/skills/$NAME"
[[ -d "$DEST/agents/AGENT_NAME" ]] && mv "$DEST/agents/AGENT_NAME" "$DEST/agents/$NAME"

# --- Replace placeholders in all files ---
# Order matters: replace longer/more-specific tokens first.
find "$DEST" -type f | while IFS= read -r file; do
  sed -i \
    -e "s/PLUGIN_NAME/$NAME/g" \
    -e "s/SKILL_NAME/$NAME/g" \
    -e "s/AGENT_NAME/$NAME/g" \
    -e "s/skill-name/$NAME/g" \
    -e "s/agent-name/$NAME/g" \
    "$file"
done

echo "Created: $DEST"
echo ""
echo "Next steps:"
echo "  1. Edit $DEST/.claude-plugin/plugin.json"
echo "     → set description and keywords"
if [[ "$TYPE" == "skill" ]]; then
  echo "  2. Edit $DEST/skills/$NAME/SKILL.md"
  echo "     → write trigger description, steps, and constraints"
fi
if [[ "$TYPE" == "agent" ]]; then
  echo "  3. Edit $DEST/agents/$NAME/SKILL.md"
  echo "     → write agent purpose, steps, and constraints"
fi
echo ""
echo "  Test:    claude --plugin-dir $DEST"
echo "  Install: claude plugin install $DEST"
